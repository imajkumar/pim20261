{
  "name": "pimcore/skeleton",
  "type": "project",
  "license": "proprietary",
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "process-timeout": 0,
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/runtime": true
    }
  },
  "prefer-stable": true,
  "minimum-stability": "dev",
  "repositories": [
    {
      "type": "path",
      "url": "bundles/ayra-bundle",
      "options": {
        "symlink": true
      }
    }
  ],
  "require": {
    "php": "~8.4.0 || ~8.5.0",
    "pimcore/pimcore": "^2026.1.0",
    "pimcore/platform-version": "^2026.1.0",
    "ayra/ayra-bundle": "*",
    "pimcore/quill-bundle": "*",
    "pimcore/studio-ui-bundle": "*",
    "pimcore/studio-backend-bundle": "*",
    "symfony/amqp-messenger": "^7.4",
    "symfony/dotenv": "^7.4",
    "symfony/runtime": "^7.4"
  },
  "require-dev": {
    "codeception/codeception": "^5.3",
    "codeception/module-symfony": "^3.5"
  },
  "suggest": {
    "pimcore/data-hub": "Universal data interface for GraphQL, CSV and other formats"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "Pimcore\\Model\\DataObject\\": "var/classes/DataObject"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": "Pimcore\\Composer::postCreateProject",
    "post-install-cmd": [
      "Pimcore\\Composer::postInstall",
      "@pimcore-scripts"
    ],
    "post-update-cmd": [
      "Pimcore\\Composer::postUpdate",
      "@pimcore-scripts"
    ],
    "pimcore-scripts": [
      "Pimcore\\Composer::clearCache",
      "Pimcore\\Composer::installAssets"
    ]
  }
}
