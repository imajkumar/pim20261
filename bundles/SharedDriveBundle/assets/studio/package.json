{
  "name": "SharedDriveBundle-studio",
  "version": "0.0.1",
  "scripts": {
    "dev": "NODE_ENV=development rsbuild build",
    "dev-server": "NODE_ENV=dev-server rsbuild dev",
    "build": "rsbuild build",
    "postbuild": "DEST=../../../../public/bundles/shareddrive/studio/build; SRC=../../public/studio/build; if [ -L ../../../../public/bundles/shareddrive ]; then exit 0; fi; mkdir -p \"$DEST\" && cp -r \"$SRC\"/* \"$DEST\"/",
    "check-types": "tsc --noEmit"
  },
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@module-federation/rsbuild-plugin": "^2.2.3",
    "@rsbuild/core": "^1.3.21",
    "@rsbuild/plugin-react": "^1.3.1",
    "@types/react-dom": "18.3.x",
    "@types/webpack-env": "^1.18.4",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@pimcore/studio-ui-bundle": "^1.0.0-canary.20260325-113631-293aa9b",
    "antd": "5.22.x",
    "antd-style": "^3.7.1",
    "inversify": "6.1.x",
    "react": "18.3.x",
    "react-dom": "18.3.x",
    "reflect-metadata": "^0.2.2",
    "uuid": "^10.0.0"
  },
  "overrides": {
    "axios": "1.13.6"
  }
}
